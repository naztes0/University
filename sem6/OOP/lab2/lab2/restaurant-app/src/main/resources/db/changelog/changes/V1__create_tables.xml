<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="restaurant">

        <sql>CREATE TYPE user_role AS ENUM ('CLIENT', 'ADMIN', 'KITCHEN')</sql>
        <sql>CREATE TYPE order_status AS ENUM ('NEW', 'CONFIRMED', 'IN_KITCHEN', 'READY', 'BILLED', 'PAID')</sql>
        <sql>CREATE TYPE bill_status AS ENUM ('UNPAID', 'PAID')</sql>

        <createTable tableName="users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)"/>
            <column name="role" type="user_role">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="menu_items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(50)"/>
            <column name="available" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>

        <createTable tableName="orders">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_orders_user" references="users(id)"/>
            </column>
            <column name="table_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="order_status">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="order_items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints foreignKeyName="fk_order_items_order" references="orders(id)"/>
            </column>
            <column name="menu_item_id" type="BIGINT">
                <constraints foreignKeyName="fk_order_items_menu" references="menu_items(id)"/>
            </column>
            <column name="quantity" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="price_at_order" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="bills">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints foreignKeyName="fk_bills_order" references="orders(id)" unique="true"/>
            </column>
            <column name="total_amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="bill_status">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="payments">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="bill_id" type="BIGINT">
                <constraints foreignKeyName="fk_payments_bill" references="bills(id)"/>
            </column>
            <column name="amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

    </changeSet>
</databaseChangeLog>